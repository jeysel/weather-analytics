# airflow/.env
# Copie para .env e preencha. NUNCA commite o .env real.
#
# IMPORTANTE: o postgresql/docker-compose.yml deve estar rodando ANTES de subir
# este Airflow, pois a rede weather_network é criada por ele.

# ─── Airflow ────────────────────────────────────────────────────────────────
AIRFLOW_UID=50000

# ─── PostgreSQL (weather_staging — já existe, criado pelo postgresql/docker-compose) ──
# O scheduler acessa o weather_postgres via rede weather_network.
# Host = nome do container (weather_postgres), não o service name.
POSTGRES_HOST=weather_postgres
POSTGRES_PORT=5432
POSTGRES_DB=weather_staging
POSTGRES_USER=weather_user
POSTGRES_PASSWORD=MESMO_VALOR_DO_postgresql/.env

# ─── dbt ────────────────────────────────────────────────────────────────────
# Aponta para o mesmo profiles.yml que você já usa com o docker-compose do dbt.
# Use caminho absoluto (não use ~, Docker não expande til em volume mounts).
# Exemplo Linux/Mac: /home/seu_usuario/.dbt
# Exemplo Windows:   C:/Users/seu_usuario/.dbt
DBT_PROFILES_DIR=/home/seu_usuario/.dbt

DBT_SOURCE_DATABASE=weather_staging
DBT_SOURCE_SCHEMA=raw

# ─── GCP / BigQuery ─────────────────────────────────────────────────────────
GCP_PROJECT_ID=seu-projeto-gcp
BIGQUERY_DATASET=weather_dw
BIGQUERY_LOCATION=southamerica-east1
# O arquivo gcp-service-account.json é montado automaticamente em /secrets/gcp.json
# a partir de ../postgresql/secrets/gcp-service-account.json
