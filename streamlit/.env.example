# GCP project that owns the BigQuery datasets
GCP_PROJECT_ID=seu-projeto-gcp

# BigQuery dataset where dbt marts landed (Evidence config shows "marts")
BIGQUERY_DATASET=marts

# Dataset where dbt seeds landed (locations table); defaults to BIGQUERY_DATASET if unset
BIGQUERY_SEEDS_DATASET=seeds

# Absolute path to the GCP service account JSON key on the server
GOOGLE_APPLICATION_CREDENTIALS=/home/ubuntu/secrets/gcp-service-account.json
