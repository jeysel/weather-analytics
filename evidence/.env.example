# ── BigQuery (prod) ───────────────────────────────────────────────────────────
# Projeto GCP onde o BigQuery está hospedado
GCP_PROJECT_ID=seu-projeto-gcp

# Dataset gerado pelo dbt (padrão: weather_dw_marts)
BQ_MARTS_DATASET=weather_dw_marts

# Caminho para o arquivo JSON da Service Account GCP
# O mesmo arquivo usado pelo dbt para o target prod
GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service-account.json

# ── PostgreSQL (dev local) ─────────────────────────────────────────────────────
# Copiar os mesmos valores do postgresql/.env
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=weather_staging
POSTGRES_USER=weather_user
POSTGRES_PASSWORD=weather_pass

# Schema onde os marts do dbt foram materializados no PostgreSQL (dev)
# Formato padrão dbt: {target_schema}_{custom_schema}
PG_MARTS_SCHEMA=dbt_dev_marts
