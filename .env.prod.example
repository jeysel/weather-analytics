# Variáveis de ambiente para produção (Lightsail)
# Copie para .env.prod e preencha com os valores reais.
# NUNCA commite o arquivo .env.prod — ele está no .gitignore.

# ── GCP / BigQuery ────────────────────────────────────────────────────────────
GCP_PROJECT_ID=YOUR_GCP_PROJECT_ID
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp-service-account.json

# ── Datasets BigQuery ─────────────────────────────────────────────────────────
BIGQUERY_RAW_DATASET=weather_raw          # destino da ingestão (ingest.py)
BIGQUERY_DBT_DATASET=weather_dw          # dataset base do dbt (profiles.yml)
BIGQUERY_DATASET=marts                    # dataset lido pelo Streamlit
BIGQUERY_SEEDS_DATASET=seeds             # dataset de seeds lido pelo Streamlit
BIGQUERY_LOCATION=southamerica-east1
